[includeIf "gitdir:~/personal-files/"]
    path = ~/personal-files/.gitconfig
[init]
	defaultBranch = main
[pager]
	branch = false
[pull]
	rebase = true
[fetch]
	prune = true
[core]
	editor = nvim
	excludesFile = $HOME/.gitignore_global
[alias]
	sw = switch
	br = branch
	ci = commit
	st = status
	unstage = reset HEAD --
	last = log -1 HEAD
[commit]
	gpgsign = true
